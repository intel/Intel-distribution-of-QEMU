From 5417155ee6e8da2924040260195f03eea0a4b902 Mon Sep 17 00:00:00 2001
From: Michael Tokarev <mjt@tls.msk.ru>
Date: Sat, 3 Aug 2024 05:40:00 +0300
Subject: [PATCH] Revert "hw/virtio: move stubs out of stubs/"

This reverts commit f2604d8508a12a2060e854283fa076c9f09d1d10.
---
 hw/virtio/meson.build                                | 2 --
 stubs/meson.build                                    | 1 +
 hw/virtio/virtio-md-stubs.c => stubs/virtio-md-pci.c | 0
 3 files changed, 1 insertion(+), 2 deletions(-)
 rename hw/virtio/virtio-md-stubs.c => stubs/virtio-md-pci.c (100%)

diff --git a/hw/virtio/meson.build b/hw/virtio/meson.build
index 621fc65454..d7f18c96e6 100644
--- a/hw/virtio/meson.build
+++ b/hw/virtio/meson.build
@@ -87,8 +87,6 @@ specific_virtio_ss.add_all(when: 'CONFIG_VIRTIO_PCI', if_true: virtio_pci_ss)
 system_ss.add_all(when: 'CONFIG_VIRTIO', if_true: system_virtio_ss)
 system_ss.add(when: 'CONFIG_VIRTIO', if_false: files('vhost-stub.c'))
 system_ss.add(when: 'CONFIG_VIRTIO', if_false: files('virtio-stub.c'))
-system_ss.add(when: 'CONFIG_VIRTIO_MD', if_false: files('virtio-md-stubs.c'))
-
 system_ss.add(files('virtio-hmp-cmds.c'))
 
 specific_ss.add_all(when: 'CONFIG_VIRTIO', if_true: specific_virtio_ss)
diff --git a/stubs/meson.build b/stubs/meson.build
index 772a3e817d..93f873ee76 100644
--- a/stubs/meson.build
+++ b/stubs/meson.build
@@ -70,6 +70,7 @@ if have_system
   stub_ss.add(files('target-monitor-defs.c'))
   stub_ss.add(files('win32-kbd-hook.c'))
   stub_ss.add(files('xen-hw-stub.c'))
+  stub_ss.add(files('virtio-md-pci.c'))
 endif
 
 if have_system or have_user
diff --git a/hw/virtio/virtio-md-stubs.c b/stubs/virtio-md-pci.c
similarity index 100%
rename from hw/virtio/virtio-md-stubs.c
rename to stubs/virtio-md-pci.c
-- 
2.39.2

